<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow layer (simulates box-shadow: 2px 4px 4px 0px #00000014) -->
    <item android:left="2dp" android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#14000000" /> <!-- 8% black shadow -->
            <corners
                android:topRightRadius="7dp"
                android:bottomRightRadius="7dp"
                android:topLeftRadius="0dp"
                android:bottomLeftRadius="0dp" />
        </shape>
    </item>

    <!-- Foreground layer: semi-transparent white -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#CCFFFFFF"/> <!-- 80% white: adjust as needed -->
            <corners
                android:topRightRadius="7dp"
                android:bottomRightRadius="7dp"
                android:topLeftRadius="0dp"
                android:bottomLeftRadius="0dp" />
        </shape>
    </item>

</layer-list>
