<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/login_nav"
    app:startDestination="@id/signUpFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.app.adhyatmah.presentation.ui.login.LoginFragment"
        android:label="LoginFragment" >
        <action
            android:id="@+id/action_loginFragment_to_otpFragment"
            app:destination="@id/otpFragment" />
        <action
            android:id="@+id/action_loginFragment_to_signUpFragment"
            app:destination="@id/signUpFragment" />
        <action
            android:id="@+id/action_loginFragment_to_forgotFragment"
            app:destination="@id/forgotFragment" />
    </fragment>
    <fragment
        android:id="@+id/otpFragment"
        android:name="com.app.adhyatmah.presentation.ui.login.OtpFragment"
        android:label="OtpFragment" >
        <action
            android:id="@+id/action_otpFragment_to_mainActivity"
            app:destination="@id/mainActivity" />
    </fragment>
    <activity
        android:id="@+id/mainActivity"
        android:name="com.app.adhyatmah.presentation.ui.activity.MainActivity"
        android:label="MainActivity" />

    <fragment
        android:id="@+id/signUpFragment"
        android:name="com.app.adhyatmah.presentation.ui.login.SignUpFragment"
        android:label="SignUpFragment">

        <action
            android:id="@+id/action_signUpFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_signUpFragment_to_termConditionFragment"
            app:destination="@id/termConditionFragment" />

    </fragment>
    <fragment
        android:id="@+id/forgotFragment"
        android:name="com.app.adhyatmah.presentation.ui.login.ForgotFragment"
        android:label="ForgotFragment" />
    <fragment
        android:id="@+id/termConditionFragment"
        android:name="com.app.adhyatmah.presentation.ui.fragment.TermConditionFragment"
        android:label="TermConditionFragment" />
    <fragment
        android:id="@+id/enterNumberFragment"
        android:name="com.app.adhyatmah.presentation.ui.login.EnterNumberFragment"
        android:label="EnterNumberFragment" />

</navigation>