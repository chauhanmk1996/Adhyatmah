        android:label="ConfirmBookingFragment" />
    <fragment
        android:id="@+id/dateTimeSelectionFragment"
        android:name="com.app.adhyatmah.presentation.ui.pandit_ji.DateTimeSelectionFragment"
        android:label="DateTimeSelectionFragment" />
    <fragment
        android:id="@+id/bookingDetailsFragment"
        android:name="com.app.adhyatmah.presentation.ui.pandit_ji.BookingDetailsFragment"
        android:label="BookingDetailsFragment" />
    <fragment
        android:id="@+id/chooseServiceFragment"
        android:name="com.app.adhyatmah.presentation.ui.pandit_ji.ChooseServiceFragment"
        android:label="ChooseServiceFragment" />
    <fragment
        android:id="@+id/chooseAddOnFragment"
        android:name="com.app.adhyatmah.presentation.ui.pandit_ji.ChooseAddOnFragment"
        android:label="ChooseAddOnFragment" />
    <fragment
        android:id="@+id/selectLanguageFragment"
        android:name="com.app.adhyatmah.presentation.ui.pandit_ji.SelectLanguageFragment"
        android:label="SelectLanguageFragment" />
    <fragment
        android:id="@+id/categoryProductFragment"
        android:name="com.app.adhyatmah.presentation.ui.fragment.CategoryProductFragment"
        android:label="CategoryProductFragment" />
    <fragment
        android:id="@+id/chooseLanguageFragment"
        android:name="com.app.adhyatmah.presentation.ui.fragment.ChooseLanguageFragment"
        android:label="ChooseLanguageFragment" />
    <fragment
        android:id="@+id/popularPujaFragment"
        android:name="com.app.adhyatmah.presentation.ui.fragment.PopularPujaFragment"
