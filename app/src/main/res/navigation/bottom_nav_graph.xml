        android:name="com.app.adhyatmah.presentation.ui.fragment.MyOrderDetailsFragment"
        android:label="MyOrderDetailsFragment">
        <action
            android:id="@+id/action_myOrderDetailsFragment_to_trackOrderFragment"
            app:destination="@id/trackOrderFragment" />
        <action
            android:id="@+id/action_myOrderDetailsFragment_to_myOrderFragment"
            app:destination="@id/myOrderFragment" />
    </fragment>

