        android:id="@+id/paymentGatewayFragment"
        android:name="com.app.adhyatmah.presentation.ui.fragment.PaymentGatewayFragment"
        android:label="PaymentGatewayFragment">
        <action
            android:id="@+id/action_paymentGatewayFragment_to_congratulationFragment"
            app:destination="@id/congratulationFragment" />
    </fragment>
    <fragment
        android:id="@+id/brandFragment"
        android:name="com.app.adhyatmah.presentation.ui.fragment.BrandFragment"
        android:label="BrandFragment">
        <action
            android:id="@+id/action_brandFragment_to_filterFragment"
            app:destination="@id/filterFragment"
            app:launchSingleTop="true"
            app:popUpTo="@id/filterFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/trackOrderFragment"
        android:name="com.app.adhyatmah.presentation.ui.fragment.TrackOrderFragment"
        android:label="TrackOrderFragment" />
    <fragment
        android:id="@+id/blogDetailsFragment"
        android:name="com.app.adhyatmah.presentation.ui.fragment.BlogDetailsFragment"
        android:label="BlogDetailsFragment" />
    <fragment
        android:id="@+id/razorpayFragment"
        android:name="com.app.adhyatmah.presentation.ui.fragment.RazorpayFragment"
