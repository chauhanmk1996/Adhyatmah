            android:id="@+id/action_searchListFragment_to_productDetailsFragment"
            app:destination="@id/productDetailsFragment" />
    </fragment>
    <fragment
        android:id="@+id/congratulationFragment"
        android:name="com.app.adhyatmah.presentation.ui.fragment.CongratulationFragment"
        android:label="CongratulationFragment">
        <action
            android:id="@+id/action_congratulationFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
