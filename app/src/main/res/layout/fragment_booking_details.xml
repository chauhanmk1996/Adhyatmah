<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <!-- optional binding variables -->
    </data>

    <androidx.core.widget.NestedScrollView
        android:fillViewport="true"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:paddingTop="50dp"
        android:paddingHorizontal="16dp">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/backBtn"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/back_btn"
                        app:tint="@color/black" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/booking_details"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Profile Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginTop="24dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/profileImage"
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/CircleImageView"
                        android:src="@drawable/placeholder_icon" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/userName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:visibility="gone"
                        android:id="@+id/bookingId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Booking ID: "
                        android:textColor="@color/gray"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Info Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp">

                    <!-- Puja Booked -->
                    <LinearLayout
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:visibility="gone"
                            app:tint="@color/orange" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="@string/about"
                            android:textColor="@color/orange"
                            android:textStyle="bold"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatTextView
                        android:visibility="visible"

                        android:id="@+id/about"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Shiv Puja"
                        android:textColor="@color/black"
                        android:textSize="15sp" />

                    <View
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#E0E0E0" />

                    <!-- Package Booked -->
                    <LinearLayout
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:visibility="gone"
                            app:tint="@color/orange" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="Package Booked"
                            android:textColor="@color/orange"
                            android:textStyle="bold"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatTextView
                        android:visibility="gone"
                        android:id="@+id/packageBooked"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="1.25 lakh mantra"
                        android:textColor="@color/black"
                        android:textSize="15sp" />

                    <View
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#E0E0E0" />

                    <!-- Address -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:visibility="gone"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/location_icon"
                            app:tint="@color/orange" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="@string/booking_address"
                            android:textColor="@color/orange"
                            android:textStyle="bold"
                            android:textSize="16sp" />
                    </LinearLayout>


                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/locality_et"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:imeOptions="actionNext"
                        android:inputType="textPersonName"
                        android:background="@drawable/rectangle_radius_16_background_f7f7f7"
                        android:fontFamily="@font/jost"
                        android:hint="@string/locality_area_street"
                        android:paddingHorizontal="15dp"
                        android:maxLines="1"
                        android:maxLength="80"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/address_tv" />


                    <LinearLayout
                        android:id="@+id/pin_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/landmark_et"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/pin_code_et"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="16dp"
                            android:layout_weight="1"
                            android:background="@drawable/rectangle_radius_16_background_f7f7f7"
                            android:fontFamily="@font/jost"
                            android:hint="@string/pin_code"
                            android:imeOptions="actionNext"
                            android:inputType="number"
                            android:maxLength="10"
                            android:paddingHorizontal="15dp"
                            android:layout_marginEnd="10dp"/>

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/city_et"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:maxLines="1"
                            android:maxLength="30"
                            android:inputType="text"
                            android:imeOptions="actionNext"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/rectangle_radius_16_background_f7f7f7"
                            android:fontFamily="@font/jost"
                            android:hint="@string/city"
                            android:paddingHorizontal="15dp"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"/>



                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/landmark_et"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/state"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="16dp"
                            android:layout_weight="1"
                            android:background="@drawable/rectangle_radius_16_background_f7f7f7"
                            android:fontFamily="@font/jost"
                            android:hint="@string/state"
                            android:imeOptions="actionNext"
                            android:inputType="text"
                            android:maxLength="10"
                            android:paddingHorizontal="15dp"
                            android:layout_marginEnd="10dp"/>

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/country"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:maxLines="1"
                            android:maxLength="30"
                            android:inputType="text"
                            android:imeOptions="actionNext"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/rectangle_radius_16_background_f7f7f7"
                            android:fontFamily="@font/jost"
                            android:hint="@string/country"
                            android:paddingHorizontal="15dp"
                            android:layout_weight="1"
                            android:layout_marginStart="10dp"/>



                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#E0E0E0" />


                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/changeAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/change_address"
                    android:letterSpacing="0"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/theme"
                    android:layout_marginBottom="24dp"/>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/next"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:backgroundTint="@color/theme"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"                app:cornerRadius="12dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>
</layout>
