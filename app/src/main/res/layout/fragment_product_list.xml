<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:background="@color/black_opacity_10"
        android:layout_height="match_parent"
        tools:context=".presentation.ui.fragment.ProductListFragment">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            android:src="@drawable/back_btn_1"
            android:layout_marginTop="50dp"
            android:layout_marginStart="24dp"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_height="wrap_content"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/header"
            android:layout_width="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="Men’s T-shirt"
            android:textSize="20dp"
            android:textColor="@color/black"
            app:layout_constraintBottom_toBottomOf="@+id/backButton"
            app:layout_constraintTop_toTopOf="@+id/backButton"
            android:fontFamily="@font/muktamahee_semibold"
            android:layout_height="wrap_content"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/searchId"
            android:visibility="gone"
            android:layout_width="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/backButton"
            app:layout_constraintTop_toTopOf="@+id/backButton"
            android:src="@drawable/search_icon_1"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_height="wrap_content"/>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/filterMainLayout"
            android:layout_width="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="40dp"
            android:paddingVertical="6dp"
            android:paddingHorizontal="3dp"
            android:layout_marginHorizontal="30dp"
            android:background="@drawable/rectangle_radius_16_background_f7f7f7"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/backButton"
            android:layout_height="wrap_content">


            <androidx.appcompat.widget.LinearLayoutCompat
                android:visibility="gone"
                android:id="@+id/filterLayoutId"
                android:layout_width="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/filterLayout"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:src="@drawable/filter_icon"
                    android:layout_marginStart="24dp"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_height="wrap_content"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/filterText"
                    android:layout_width="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:text="Filters"
                    android:textSize="11dp"
                    android:layout_gravity="center"
                    android:textColor="@color/black_222222"
                    app:layout_constraintBottom_toBottomOf="@+id/backButton"
                    app:layout_constraintTop_toTopOf="@+id/backButton"
                    android:fontFamily="@font/muktamahee_regular"
                    android:layout_height="wrap_content"/>


            </androidx.appcompat.widget.LinearLayoutCompat>
         <androidx.appcompat.widget.LinearLayoutCompat
             android:layout_marginEnd="20dp"
             android:id="@+id/shortLayout"
                android:layout_width="wrap_content"
                android:orientation="horizontal"

          android:layout_height="wrap_content">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/shortImg"
                    android:layout_width="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    android:src="@drawable/short_icon"
                    android:layout_marginStart="24dp"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_height="wrap_content"/>
             <androidx.appcompat.widget.AppCompatTextView
                 android:id="@+id/shortText"
                 android:layout_width="wrap_content"
                 app:layout_constraintStart_toStartOf="parent"
                 app:layout_constraintEnd_toEndOf="parent"
                 android:text="@string/sort"
                 android:textSize="11dp"
                 android:layout_gravity="center"
                 android:textColor="@color/black_222222"
                 app:layout_constraintBottom_toBottomOf="@+id/backButton"
                 app:layout_constraintTop_toTopOf="@+id/backButton"
                 android:fontFamily="@font/muktamahee_regular"
                 android:layout_height="wrap_content"/>


         </androidx.appcompat.widget.LinearLayoutCompat>

        </androidx.appcompat.widget.LinearLayoutCompat>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/productListRecyclerView"
            android:layout_width="match_parent"
            android:layout_marginTop="20dp"
            tools:itemCount="3"
            android:layout_marginBottom="30dp"
            android:layout_marginStart="23dp"
            tools:listitem="@layout/home_blog_recyclerview"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/filterMainLayout"
            android:layout_height="0dp"/>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>