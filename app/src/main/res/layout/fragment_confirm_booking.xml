<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        tools:context=".presentation.ui.fragment.ConfirmOrderFragment"
        android:background="@color/black_opacity_10"
        android:layout_height="match_parent">
        <ScrollView
            android:fillViewport="true"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/bagLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.appcompat.widget.AppCompatImageView

                    android:layout_marginStart="16dp"
                    android:id="@+id/back_img"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/back_btn_1"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginTop="50dp"/>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/confirm_order_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/confirm_booking"
                    android:textSize="20sp"
                    android:textColor="#272727"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/back_img"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="50dp"/>

                <androidx.appcompat.widget.AppCompatTextView

                    android:layout_marginHorizontal="16dp"
                    android:id="@+id/select_payment_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/review_your_order"
                    android:textSize="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/confirm_order_tv"
                    android:fontFamily="@font/muktamahee_semibold"
                    android:textColor="#272727"/>
                <androidx.constraintlayout.widget.ConstraintLayout

                    android:layout_marginHorizontal="16dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="10dp"
                    android:id="@+id/panditji_detail"
                    app:layout_constraintTop_toBottomOf="@id/select_payment_tv"
                    android:layout_width="match_parent"
                    android:background="@drawable/rec_white_bg_box"
                    android:layout_height="wrap_content"
                    >
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/midLayout"
                        android:layout_marginStart="25dp"
                        android:layout_width="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/cardView"
                        app:layout_constraintEnd_toEndOf="@id/panditji_detail"
                        android:layout_height="match_parent">
                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/etUserName"
                            android:layout_width="0dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:fontFamily="@font/muktamahee_regular"
                            android:textSize="15dp"
                            android:textColor="@color/black_272727"
                            android:layout_height="wrap_content"/>

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/etAddress"
                            android:layout_width="0dp"
                            app:layout_constraintTop_toBottomOf="@+id/etUserName"
                            android:maxLines="2"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:ellipsize="end"
                            android:fontFamily="@font/muktamahee_regular"
                            android:textSize="15dp"
                            android:textColor="@color/black_272727"
                            app:layout_constraintStart_toStartOf="parent"
                            android:layout_height="wrap_content"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardView"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_width="50dp"
                        android:layout_marginStart="10dp"
                        app:cardCornerRadius="30dp"
                        android:elevation="-3dp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_height="50dp">
                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/userImage"
                            android:elevation="3dp"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"/>

                    </androidx.cardview.widget.CardView>


                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:visibility="gone"
                    android:id="@+id/puja_list_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scrollbars="vertical"
                    android:isScrollContainer="true"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/panditji_detail"
                    android:layout_marginTop="16dp" />
                <com.google.android.material.card.MaterialCardView

                    android:layout_marginHorizontal="20dp"
                    app:layout_constraintTop_toBottomOf="@id/puja_list_recycler"
                    android:id="@+id/cardService"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="6dp"
                    app:cardCornerRadius="12dp"
                    app:strokeColor="@color/theme"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvPoojaType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/theme"
                            android:textSize="16sp"
                            android:fontFamily="@font/muktamahee_bold" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/black"
                            android:textSize="13sp"
                            android:fontFamily="@font/muktamahee_regular" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="6dp">

                            <androidx.appcompat.widget.AppCompatTextView
                                android:layout_weight="1"
                                android:id="@+id/tvPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/black"
                                android:textSize="14sp"
                                android:fontFamily="@font/muktamahee_bold" />

                            <androidx.appcompat.widget.AppCompatTextView
                                android:layout_weight="1"
                                android:id="@+id/tvDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/black"
                                android:textSize="14sp"
                                android:fontFamily="@font/muktamahee_regular" />
                        </LinearLayout>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_marginTop="6dp"
                            android:id="@+id/tvTiming"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/black"
                            android:textSize="14sp"
                            android:fontFamily="@font/muktamahee_medium" />
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_marginTop="6dp"
                            android:id="@+id/tvLanguages"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/black"
                            android:textSize="14sp"
                            android:fontFamily="@font/muktamahee_medium" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/empty_text_view"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/no_items_in_your_bag"
                    android:textSize="16sp"
                    android:textColor="@android:color/darker_gray"
                    android:gravity="center"
                    android:visibility="gone"
                    android:fontFamily="@font/jost_bold"
                    app:layout_constraintTop_toBottomOf="@id/select_payment_tv"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="24dp"/>


                <androidx.constraintlayout.widget.ConstraintLayout

                    android:layout_marginHorizontal="16dp"
                    android:id="@+id/details_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="20sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardService"
                    android:layout_marginTop="25dp"
                    android:background="@drawable/rectangle_white">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/payment_plan_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:text="@string/payment_plan"
                        android:layout_marginTop="16dp"
                        android:layout_marginStart="16dp"
                        android:textSize="17sp"
                        android:fontFamily="@font/muktamahee_semibold"
                        android:textColor="#272727" />

                    <View
                        android:id="@+id/view_line0"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/payment_plan_tv"
                        android:background="#E3E3E3"
                        android:layout_marginTop="15dp" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/order_address_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/view_line0"
                        android:text="@string/gst"
                        android:layout_marginTop="16dp"
                        android:layout_marginStart="16dp"
                        android:textSize="15sp"
                        android:fontFamily="@font/muktamahee_semibold"
                        android:textColor="#272727" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/totalAmountPrice"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/view_line0"
                        android:gravity="end"
                        android:textSize="15sp"
                        android:maxLines="1"
                        android:fontFamily="@font/jost"
                        android:textColor="#272727"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="16dp" />
                    <View
                        android:id="@+id/view_line1"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/order_address_tv"
                        android:background="#E3E3E3"
                        android:layout_marginTop="15dp" />
                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/platformFee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/view_line1"
                        android:text="@string/platform_fee"
                        android:layout_marginTop="16dp"
                        android:layout_marginStart="16dp"
                        android:textSize="15sp"
                        android:fontFamily="@font/muktamahee_semibold"
                        android:textColor="#272727" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/platformFeeText"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/view_line1"
                        android:text="₹ 0"
                        android:gravity="end"
                        android:textSize="15sp"
                        android:maxLines="1"
                        android:fontFamily="@font/jost"
                        android:textColor="#272727"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="16dp" />

                    <View
                        android:id="@+id/view_line"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/platformFee"
                        android:background="#E3E3E3"
                        android:layout_marginTop="15dp" />

                    <!-- PAY FULL ROW -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/total_amount_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/view_line"
                        android:text="@string/pay_full"
                        android:layout_marginTop="16dp"
                        android:layout_marginStart="16dp"
                        android:textSize="15sp"
                        android:fontFamily="@font/muktamahee_semibold"
                        android:textColor="#272727" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/imgPayFullSelect"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        app:layout_constraintEnd_toStartOf="@id/payFullTv"
                        app:layout_constraintTop_toTopOf="@id/total_amount_tv"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/unselected_rounded_btn" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/payFullTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/view_line"
                        android:textSize="15sp"
                        android:fontFamily="@font/jost"
                        android:textColor="#272727"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="16dp" />

                    <View
                        android:id="@+id/view_line2"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/payFullTv"
                        android:background="#E3E3E3"
                        android:layout_marginTop="15dp" />

                    <!-- PAY ADVANCE ROW -->
                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/pay_with_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@id/view_line2"
                        android:text="@string/pay_advance"
                        android:layout_marginTop="16dp"
                        android:layout_marginStart="16dp"
                        android:textSize="15sp"
                        android:fontFamily="@font/muktamahee_semibold"
                        android:textColor="#272727" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/imgPayAdvanceSelect"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        app:layout_constraintEnd_toStartOf="@id/payAdvanceTv"
                        app:layout_constraintTop_toTopOf="@id/pay_with_tv"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/unselected_rounded_btn" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/payAdvanceTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/view_line2"
                        android:textSize="15sp"
                        android:fontFamily="@font/jost"
                        android:textColor="#272727"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="16dp" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <com.google.android.material.button.MaterialButton
                    android:elevation="0dp"
                    app:elevation="0dp"
                    android:id="@+id/continue_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/book"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/theme"
                    android:layout_marginTop="8dp"
                    android:layout_marginHorizontal="16dp"
                    app:cornerRadius="12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/details_layout" />
                <WebView
                    android:elevation="1dp"
                    android:id="@+id/webView"
                    android:visibility="gone"
                    android:paddingHorizontal="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    app:layout_constraintTop_toTopOf="@+id/confirm_order_tv"
                    app:layout_constraintBottom_toBottomOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>