<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_heading"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="center"
                android:src="@drawable/back"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_semi_bold"
                android:text="@string/confirm_booking"
                android:textColor="@color/black"
                android:textSize="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="#FFF7ED"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cl_heading">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/nv_cart"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintBottom_toTopOf="@+id/btn_book"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_pandit_ji_details"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/muktamahee_semibold"
                        android:text="@string/pandit_ji_details"
                        android:textColor="#272727"
                        android:textSize="16dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_pandit_ji_detail"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rec_white_bg_box"
                        app:layout_constraintTop_toBottomOf="@id/tv_pandit_ji_details">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/cv_pic"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="12dp"
                            android:elevation="2dp"
                            app:cardCornerRadius="48dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/iv_pandit_pic"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent" />

                        </androidx.cardview.widget.CardView>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="12dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/cv_pic"
                            app:layout_constraintTop_toTopOf="parent">

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tv_pandit_name"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:fontFamily="@font/inter_regular"
                                android:maxLines="1"
                                android:textColor="@color/black_272727"
                                android:textSize="15dp"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                tools:text="Mayank" />

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tv_pandit_address"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:fontFamily="@font/inter_regular"
                                android:maxLines="1"
                                android:textColor="@color/black_272727"
                                android:textSize="15dp"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/tv_pandit_name"
                                tools:text="Mayank" />

                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_address_details"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/muktamahee_semibold"
                        android:text="@string/address_details"
                        android:textColor="#272727"
                        android:textSize="16dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/cl_pandit_ji_detail" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_address_details"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rec_white_bg_box"
                        app:layout_constraintTop_toBottomOf="@id/tv_address_details">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_select_address"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="12dp"
                            android:layout_marginVertical="12dp"
                            android:backgroundTint="@color/theme"
                            android:text="@string/select_address"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:visibility="gone"
                            app:cornerRadius="12dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_selected_address"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_regular"
                            android:padding="12dp"
                            android:textColor="@color/black_272727"
                            android:textSize="15dp"
                            android:visibility="gone"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/tv_change"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            tools:text="Mayank" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_change"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:fontFamily="@font/inter_bold"
                            android:padding="8dp"
                            android:text="@string/change"
                            android:textColor="@color/theme"
                            android:visibility="gone"
                            android:textSize="15dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_puja_details"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/muktamahee_semibold"
                        android:text="@string/puja_details"
                        android:textColor="#272727"
                        android:textSize="16dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/cl_address_details" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cv_puja"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="12dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_puja_details"
                        app:strokeColor="@color/theme"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tv_puja_type"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_bold"
                                android:textColor="@color/theme"
                                android:textSize="16dp"
                                tools:text="Puja Type: Satynarayan Puja" />

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tv_description"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/inter_regular"
                                android:textColor="@color/black"
                                android:textSize="13dp"
                                tools:text="सत्यनारायण पूजा" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:orientation="horizontal">

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tv_price"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/inter_bold"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    tools:text="₹ 2100" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/tv_duration"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="@font/inter_regular"
                                    android:textColor="@color/black"
                                    android:textSize="14dp"
                                    tools:text="2-3 Hour" />

                            </LinearLayout>

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tv_timing"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/inter_semi_bold"
                                android:textColor="@color/black"
                                android:textSize="14dp"
                                tools:text="30 May, 2016 09:30 AM" />

                            <androidx.appcompat.widget.AppCompatTextView
                                android:id="@+id/tv_languages"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/inter_semi_bold"
                                android:textColor="@color/black"
                                android:textSize="14dp"
                                tools:text="Language(s): Hindi" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tv_addon_puja_kit_details"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/muktamahee_semibold"
                        android:text="@string/add_ons"
                        android:textColor="#272727"
                        android:textSize="16dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/cv_puja" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_puja_kit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:paddingHorizontal="8dp"
                        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_addon_puja_kit_details"
                        app:spanCount="2"
                        tools:itemCount="0"
                        tools:listitem="@layout/list_item_puja_kit_grid" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_payment_details"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/rectangle_white"
                        android:paddingBottom="20sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/rv_puja_kit">

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_payment_plan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/inter_semi_bold"
                            android:text="@string/payment_plan"
                            android:textColor="#272727"
                            android:textSize="17dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <View
                            android:id="@+id/view1"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="#E3E3E3"
                            app:layout_constraintTop_toBottomOf="@id/tv_payment_plan" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_service_price_heading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/inter_semi_bold"
                            android:text="@string/service_price"
                            android:textColor="#272727"
                            android:textSize="15dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/view1" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_service_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            android:fontFamily="@font/jost"
                            android:textColor="#272727"
                            android:textSize="15dp"
                            app:layout_constraintBottom_toBottomOf="@+id/tv_service_price_heading"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/tv_service_price_heading"
                            tools:text="₹ 100" />

                        <View
                            android:id="@+id/view2"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="#E3E3E3"
                            app:layout_constraintTop_toBottomOf="@id/tv_service_price_heading" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_add_ons_price_heading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/inter_semi_bold"
                            android:text="@string/add_ons"
                            android:textColor="#272727"
                            android:textSize="15dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/view2" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_add_ons_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            android:fontFamily="@font/jost"
                            android:textColor="#272727"
                            android:textSize="15dp"
                            app:layout_constraintBottom_toBottomOf="@+id/tv_add_ons_price_heading"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/tv_add_ons_price_heading"
                            tools:text="₹ 100" />

                        <View
                            android:id="@+id/view3"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="#E3E3E3"
                            app:layout_constraintTop_toBottomOf="@id/tv_add_ons_price_heading" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_delivery_charge_heading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/inter_semi_bold"
                            android:text="@string/delivery_charge"
                            android:textColor="#272727"
                            android:textSize="15dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/view3" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_delivery_charge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            android:fontFamily="@font/jost"
                            android:textColor="@color/green"
                            android:textSize="15dp"
                            app:layout_constraintBottom_toBottomOf="@+id/tv_delivery_charge_heading"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/tv_delivery_charge_heading"
                            tools:text="Free" />

                        <View
                            android:id="@+id/view4"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="#E3E3E3"
                            app:layout_constraintTop_toBottomOf="@id/tv_delivery_charge_heading" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_handling_charge_heading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/inter_semi_bold"
                            android:text="@string/handling_charge"
                            android:textColor="#272727"
                            android:textSize="15dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/view4" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_handling_charge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            android:fontFamily="@font/jost"
                            android:textColor="@color/green"
                            android:textSize="15dp"
                            app:layout_constraintBottom_toBottomOf="@+id/tv_handling_charge_heading"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/tv_handling_charge_heading"
                            tools:text="Free" />

                        <View
                            android:id="@+id/view5"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="#E3E3E3"
                            app:layout_constraintTop_toBottomOf="@id/tv_handling_charge_heading" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_platform_fee_heading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/inter_semi_bold"
                            android:text="@string/platform_fee"
                            android:textColor="#272727"
                            android:textSize="15dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/view5" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_platform_fee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            android:fontFamily="@font/jost"
                            android:textColor="@color/green"
                            android:textSize="15dp"
                            app:layout_constraintBottom_toBottomOf="@+id/tv_platform_fee_heading"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/tv_platform_fee_heading"
                            tools:text="Free" />

                        <View
                            android:id="@+id/view6"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="#E3E3E3"
                            app:layout_constraintTop_toBottomOf="@id/tv_platform_fee_heading" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_pay_full_heading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="16dp"
                            android:fontFamily="@font/inter_semi_bold"
                            android:text="@string/pay_full"
                            android:textColor="#272727"
                            android:textSize="15dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@id/view6" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/iv_pay_full"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/unselected_rounded_btn"
                            app:layout_constraintBottom_toBottomOf="@+id/tv_pay_full_heading"
                            app:layout_constraintEnd_toStartOf="@id/tv_pay_full"
                            app:layout_constraintTop_toTopOf="@id/tv_pay_full_heading" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_pay_full"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            android:fontFamily="@font/jost"
                            android:textColor="#272727"
                            android:textSize="15dp"
                            app:layout_constraintBottom_toBottomOf="@+id/tv_pay_full_heading"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/tv_pay_full_heading"
                            tools:text="₹ 100" />

                        <View
                            android:id="@+id/view7"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="#E3E3E3"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tv_pay_full_heading" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_pay_advance_heading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/inter_semi_bold"
                            android:text="@string/pay_advance"
                            android:textColor="#272727"
                            android:textSize="15sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@id/view7" />

                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/iv_pay_advance"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/unselected_rounded_btn"
                            app:layout_constraintBottom_toBottomOf="@+id/tv_pay_advance_heading"
                            app:layout_constraintEnd_toStartOf="@id/tv_pay_advance"
                            app:layout_constraintTop_toTopOf="@id/tv_pay_advance_heading" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tv_pay_advance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            android:fontFamily="@font/jost"
                            android:textColor="#272727"
                            android:textSize="15sp"
                            app:layout_constraintBottom_toBottomOf="@+id/tv_pay_advance_heading"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/tv_pay_advance_heading"
                            tools:text="₹ 10" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        app:layout_constraintTop_toBottomOf="@+id/cl_payment_details" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.core.widget.NestedScrollView>

            <WebView
                android:id="@+id/webView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="48dp"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_book"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="48dp"
                android:backgroundTint="@color/theme"
                android:text="@string/book"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:cornerRadius="12dp"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>