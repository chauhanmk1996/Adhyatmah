<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:background="@color/black_opacity_10"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"

        android:layout_height="match_parent"
        android:padding="16dp">
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/oneThirdGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.08" />


        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/backArrow"
            app:layout_constraintTop_toBottomOf="@+id/oneThirdGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/back_btn"
            android:paddingLeft="24dp"
            android:contentDescription="Back"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/contact_us"
            android:fontFamily="@font/muktamahee_bold"
            android:textStyle="bold"
            android:textColor="#272727"
            android:textSize="18sp"
            app:layout_constraintStart_toEndOf="@+id/backArrow"
            android:paddingLeft="16dp"
            app:layout_constraintTop_toTopOf="@id/backArrow"
            app:layout_constraintBottom_toBottomOf="@id/backArrow"
            app:layout_constraintHorizontal_bias="0" />

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            app:layout_constraintTop_toBottomOf="@id/backArrow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/introTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/introduction"
            android:fontFamily="@font/muktamahee_regular"
            android:textSize="16sp"
            android:textColor="#272727"
            android:paddingLeft="24dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="16dp" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/introText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/welcome_to_adhyatmah_your_one_stop_destination_for_all_essential_pooja_and_spiritual_items_we_believe_that_every_ritual_deserves_purity_and_authenticity_which_is_why_we_bring_you_carefully_sourced_and_high_quality_products_for_every_religious_occasion_from_daily_puja_essentials_to_festival_specific_items_we_ensure_that_your_spiritual_journey_remains_seamless_and_divine_with_adhyatmah_experience_convenience_trust_and_devotion_delivered_to_your_doorstep"
            android:fontFamily="@font/muktamahee_regular"
            android:textColorLink="#272727"
            android:textSize="14sp"
            android:textColor="#333333"
            android:paddingLeft="24dp"
            app:layout_constraintTop_toBottomOf="@id/introTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/contactTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/contact_us"
            android:fontFamily="@font/muktamahee_regular"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingLeft="24dp"
            android:textColor="#272727"
            app:layout_constraintTop_toBottomOf="@id/introText"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="24dp" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/email"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="• Email: bellaclothing@gmail.com"
            android:fontFamily="@font/muktamahee_regular"
            android:textSize="14sp"
            android:textColor="#272727"
            android:paddingLeft="24dp"
            app:layout_constraintTop_toBottomOf="@id/contactTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/instaId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="• Instagram: bella_clothing"
            android:fontFamily="@font/muktamahee_regular"
            android:textSize="14dp"
            android:textColor="#272727"
            android:paddingLeft="24dp"
            app:layout_constraintTop_toBottomOf="@id/email"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/phoneId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/muktamahee_regular"
            android:textSize="14dp"
            android:textColor="#272727"
            android:paddingLeft="24dp"
            android:text="• Phone Number: +91-1234567890"
            app:layout_constraintTop_toBottomOf="@id/instaId"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <LinearLayout
            app:layout_constraintTop_toBottomOf="@+id/phoneId"
            android:layout_width="match_parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="25dp"
            android:gravity="center"

            android:weightSum="3"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/whatsAppLayoyt"
                android:layout_width="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_gravity="center"
                android:gravity="center"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:layout_weight="1"
                    android:background="@mipmap/whatsapp_icon" />
                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="wrap_content"
                    android:text="@string/whatsapp"
                    android:layout_marginTop="5dp"
                    android:layout_gravity="center"
                    android:textColor="#333333"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:fontFamily="@font/jost_bold"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
            <LinearLayout
                android:id="@+id/gmaillayout"
                android:layout_weight="1"
                android:layout_width="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:layout_weight="1"
                    android:background="@mipmap/gmail_icon" />
                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="wrap_content"
                    android:text="@string/gmail"
                    android:fontFamily="@font/jost_bold"
                    android:layout_marginTop="5dp"
                    android:textColor="#333333"
                    android:textSize="12sp"
                    android:layout_gravity="center_horizontal"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
            <LinearLayout
                android:id="@+id/instaLayout"
                android:layout_width="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_weight="1"
                    android:background="@mipmap/insta_icon" />
                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="wrap_content"
                    android:text="@string/instagram"
                    android:textColor="#333333"
                    android:textSize="12sp"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/jost_bold"
                    android:layout_gravity="center_horizontal"
                    android:layout_height="wrap_content"/>

            </LinearLayout>


        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
</layout>