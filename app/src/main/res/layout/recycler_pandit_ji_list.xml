<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_margin="3dp"
        android:background="@drawable/panditji_item_bg"
        android:layout_height="wrap_content"
       >
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/midLayout"
            android:layout_width="0dp"
            android:layout_marginStart="25dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/cardView"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_height="match_parent">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/etUserName"
                android:layout_width="match_parent"
                android:text="Hariom Pandit"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/muktamahee_regular"
                android:textSize="15dp"
                android:textColor="@color/black_272727"
                android:layout_height="wrap_content"/>


            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/etAddress"
                android:includeFontPadding="false"
                android:layout_width="match_parent"
                android:text="Gaur city, Lucknow, Uttar Pradesh"
                android:maxLines="2"
                app:layout_constraintEnd_toEndOf="parent"
                android:ellipsize="end"
                android:fontFamily="@font/muktamahee_bold"
                android:textSize="15dp"
                android:textColor="@color/black_272727"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:layout_marginEnd="25dp"/>


            <androidx.appcompat.widget.AppCompatTextView
                android:visibility="gone"
                android:layout_marginBottom="12dp"
                android:id="@+id/etStatePincode"
                android:layout_width="match_parent"
                app:layout_constraintTop_toBottomOf="@+id/tvLanguage"
                android:text="India"
                android:maxLines="1"
                app:layout_constraintEnd_toEndOf="parent"
                 android:ellipsize="end"
                android:fontFamily="@font/muktamahee_regular"
                android:textSize="15dp"
                android:textColor="@color/black_272727"
                android:layout_height="match_parent"/>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardView"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="55dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="50dp"
            android:elevation="-3dp"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_height="55dp">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/userImage"
                android:src="@drawable/placeholder_icon"
                android:elevation="3dp"
                android:scaleType="centerCrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

        </androidx.cardview.widget.CardView>



    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>