<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        >
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/userName"
            android:layout_width="0dp"
            app:layout_constraintTop_toTopOf="parent"
            android:text="@string/email"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintEnd_toStartOf="@+id/rating"
            android:fontFamily="@font/muktamahee_semibold"
            android:textSize="15dp"
            android:layout_margin="16dp"
            android:textColor="@color/black_272727"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_height="wrap_content"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/userReview"
            android:layout_width="0dp"
            android:layout_marginTop="4dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@+id/userName"
            android:text="@string/perfect_must_buy"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintEnd_toStartOf="@+id/cardView"
            android:fontFamily="@font/muktamahee_regular"
            android:textSize="13dp"
            android:textColor="@color/black_272727"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_height="wrap_content"
            tools:ignore="NotSibling" />
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/dayId"
            android:layout_width="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@+id/userReview"
            android:text="3 days ago"
            app:lineHeight="100dp"
            android:fontFamily="@font/muktamahee_regular"
            android:textSize="11dp"
            android:textColor="@color/grey_7C7C7C"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_height="wrap_content"/>
        <androidx.appcompat.widget.AppCompatRatingBar
            android:id="@+id/rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleX="1"
            android:scaleY="1"
            android:layout_margin="16dp"
            app:layout_constraintTop_toTopOf="parent"
            android:numStars="5"
            android:stepSize="1.0"
            style="?android:attr/ratingBarStyleSmall"
            app:layout_constraintEnd_toEndOf="parent"
            />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardView"
            android:layout_width="32dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="4dp"
            app:layout_constraintTop_toBottomOf="@+id/rating"
            app:layout_constraintEnd_toEndOf="@+id/rating"
            app:layout_constraintStart_toStartOf="@+id/rating"
            android:layout_height="32dp">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/userImage"
                android:layout_width="match_parent"
                android:background="@drawable/placeholder_icon"
                android:layout_height="match_parent"/>

        </androidx.cardview.widget.CardView>
        <View
            android:id="@+id/view"
            app:layout_constraintTop_toBottomOf="@+id/dayId"
            android:layout_marginTop="18dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginHorizontal="16dp"
            android:background="@color/white_E3E3E3"
            android:layout_width="match_parent"
            android:visibility="gone"
            android:layout_height="1dp"/>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>