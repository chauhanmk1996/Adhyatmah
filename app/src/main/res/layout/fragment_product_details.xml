<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black_opacity_10"
        tools:context=".presentation.ui.fragment.ProductDetailsFragment">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/backBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="70dp"
            android:background="@drawable/back_btn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <FrameLayout
            android:id="@+id/cartContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="70dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/cartButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@mipmap/cart_icon" />

            <include
                android:id="@+id/cartBadge"
                layout="@layout/badge_layout"
                android:layout_gravity="end|top"
                android:padding="2dp" />

        </FrameLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10sp"
            android:fillViewport="true"
            app:layout_constraintBottom_toTopOf="@+id/BagBtn"
            app:layout_constraintTop_toBottomOf="@+id/backBtn">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.cardview.widget.CardView
                    android:id="@+id/viewpagerLayout"
                    android:layout_width="match_parent"
                    android:layout_height="375dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/viewpager"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/banner_3"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.cardview.widget.CardView>

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/arrowLeft"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_margin="24dp"
                    android:layout_marginTop="13dp"
                    android:elevation="4dp"
                    android:rotation="180"
                    android:src="@drawable/right_circle"
                    app:layout_constraintBottom_toBottomOf="@+id/viewpagerLayout"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/viewpagerLayout" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/arrowRight"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_margin="24dp"
                    android:layout_marginTop="13dp"
                    android:elevation="4dp"
                    android:src="@drawable/right_circle"
                    app:layout_constraintBottom_toBottomOf="@+id/viewpagerLayout"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/viewpagerLayout" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/bagIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="13dp"
                    android:elevation="4dp"
                    android:src="@drawable/bag_icon"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/fabIcon"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_marginTop="20dp"
                    android:elevation="4dp"
                    app:layout_constraintEnd_toEndOf="@+id/shareBtn"
                    app:layout_constraintStart_toStartOf="@+id/shareBtn"
                    app:layout_constraintTop_toBottomOf="@+id/bagIcon" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/shareBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:elevation="4dp"
                    android:src="@drawable/share_icon"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/fabIcon" />

                <com.app.adhyatmah.presentation.utils.IndicatorRecyclerView
                    android:id="@+id/indicatorRecyclerview"
                    android:layout_width="wrap_content"
                    android:layout_height="7dp"
                    android:layout_marginTop="10sp"
                    android:foregroundGravity="center_horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/viewpagerLayout" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/greyPullover"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:fontFamily="@font/muktamahee_regular"
                    android:textColor="@color/grey_7C7C7C"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/indicatorRecyclerview" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/price"
                    style="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="3sp"
                    android:elevation="5dp"
                    android:textColor="@color/theme"
                    android:textSize="18sp"
                    android:visibility="visible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/greyPullover" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/colorText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:elevation="5dp"
                    android:fontFamily="@font/muktamahee_semibold"
                    android:text="@string/color"
                    android:textColor="@color/black_272727"
                    android:textSize="16sp"
                    android:visibility="visible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/price" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/colorRecyclerview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:visibility="visible"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@+id/colorText" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/sizeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:elevation="5dp"
                    android:fontFamily="@font/muktamahee_semibold"
                    android:text="@string/sizes"
                    android:textColor="@color/black_272727"
                    android:textSize="16sp"
                    android:visibility="visible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/colorRecyclerview" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/sizeRecyclerview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:visibility="visible"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/sizeText" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/sizeGuideText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="23dp"
                    android:background="@drawable/rectangle_radius_12_fd3e750f"
                    android:drawableEnd="@drawable/left_arrow"
                    android:elevation="5dp"
                    android:fontFamily="@font/muktamahee_regular"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="12dp"
                    android:text="@string/size_guide"
                    android:textColor="@color/black_272727"
                    android:textSize="16sp"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/sizeRecyclerview" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/productDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="10sp"
                    android:elevation="5dp"
                    android:fontFamily="@font/muktamahee_semibold"
                    android:text="@string/product_details"
                    android:textColor="@color/black_272727"
                    android:textSize="16sp"
                    android:visibility="visible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/sizeGuideText" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/productDetailsDis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginEnd="10sp"
                    android:elevation="5dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/muktamahee_regular"
                    android:maxLines="3"
                    android:paddingVertical="5dp"
                    android:textColor="@color/grey_7C7C7C"
                    android:textSize="15sp"
                    android:visibility="visible"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/productDetails" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/numRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:elevation="5dp"
                    android:ellipsize="end"
                    android:maxLines="3"
                    android:paddingVertical="5dp"
                    android:text="4.0"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="@+id/numOfRating"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/rating" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/numRateOutOf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:elevation="5dp"
                    android:ellipsize="end"
                    android:maxLines="3"
                    android:paddingVertical="5dp"
                    android:text="@string/out_of_5"
                    android:textColor="@color/grey_7C7C7C"
                    android:textSize="18sp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="@+id/numOfRating"
                    app:layout_constraintStart_toEndOf="@+id/numRate"
                    app:layout_constraintTop_toTopOf="@+id/rating" />

                <androidx.appcompat.widget.AppCompatRatingBar
                    android:id="@+id/rating"
                    style="?android:attr/ratingBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="22dp"
                    android:numStars="5"
                    android:scaleX="1"
                    android:scaleY="1"
                    android:stepSize="1.0"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/productDetailsDis" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/numOfRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="22dp"
                    android:elevation="5dp"
                    android:ellipsize="end"
                    android:maxLines="3"
                    android:paddingVertical="5dp"
                    android:text="@string/_118_ratings"
                    android:textColor="@color/grey_7C7C7C"
                    android:textSize="18sp"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/rating" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/reviewText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="22dp"
                    android:layout_marginStart="24dp"
                    android:elevation="5dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/muktamahee_semibold"
                    android:maxLines="3"
                    android:text="@string/reviews"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/numOfRating" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/reviewRecyclerId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="25dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="22dp"
                    android:background="@drawable/rectangle_radius_16_e3e3e3_stork"
                    android:orientation="vertical"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/reviewText" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/BagBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="25dp"
            android:layout_marginEnd="22dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/rectangle_272727_radius_16"
            android:fontFamily="@font/muktamahee_semibold"
            android:text="@string/add_to_cart"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/scrollView" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>