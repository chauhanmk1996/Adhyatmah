<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
    </data>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardUpcomingContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="5dp"
        android:elevation="5dp"
        app:strokeColor="#E98347"
        app:strokeWidth="1dp"
        app:cardBackgroundColor="@color/white"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="3dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvBookingId"
                android:layout_marginStart="15dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/booking_id_123546567895"
                android:fontFamily="@font/muktamahee_semibold"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:maxLines="1"
                android:layout_marginTop="12dp"
                android:maxLength="35"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/btStatusId"
                android:layout_width="0dp"
                android:paddingVertical="4dp"
                android:paddingHorizontal="21dp"

                android:layout_marginTop="12dp"
                android:layout_marginEnd="15dp"
                android:layout_height="wrap_content"
                android:text="@string/pending"
                android:fontFamily="@font/muktamahee_semibold"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:backgroundTint="@color/red"
                android:background="@drawable/rectangle_000000_radius_12"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <androidx.cardview.widget.CardView
                android:id="@+id/imageCardView"
                android:layout_marginTop="5dp"
                android:layout_marginStart="15dp"
                app:cardCornerRadius="30dp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:layout_constraintTop_toBottomOf="@+id/btStatusId" >
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivProf"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:importantForAccessibility="no"
                    android:scaleType="centerCrop"
                    android:src="@drawable/pamdit_ji"/>
            </androidx.cardview.widget.CardView>
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/btNameId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Manish kumar"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/muktamahee_semibold"
                android:textColor="@color/black"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                android:maxLines="1"
                android:maxLength="20"
                app:layout_constraintTop_toTopOf="@+id/imageCardView"
                app:layout_constraintStart_toEndOf="@+id/imageCardView"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvAddressId1"
                android:layout_width="0dp"
                android:layout_marginTop="3dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="India"
                android:fontFamily="@font/muktamahee_regular"
                android:layout_marginEnd="5dp"
                android:ellipsize="end"
                android:maxLines="2"
                app:layout_constraintEnd_toEndOf="parent"
                android:textColor="@color/black"
                android:textSize="14sp"
                app:layout_constraintStart_toEndOf="@+id/imageCardView"
                app:layout_constraintTop_toBottomOf="@+id/btNameId"/>
            <View
                android:id="@+id/viewId"
                android:layout_width="match_parent"
                android:background="#E98347"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="6dp"
                app:layout_constraintTop_toBottomOf="@+id/tvAddressId1"
                android:layout_height="1dp"/>
            <LinearLayout
                android:id="@+id/layoutId"
                android:padding="8dp"
                android:layout_width="0dp"
                android:visibility="visible"
                app:layout_constraintTop_toBottomOf="@+id/viewId"
                app:layout_constraintEnd_toStartOf="@id/btnCancel"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_height="match_parent"
                android:orientation="vertical">



                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/tvBookingId1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pooja_booked"
                        android:fontFamily="@font/muktamahee_bold"
                        android:textColor="@color/theme"
                        android:textSize="12sp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>



                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/poojaName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/muktamahee_regular"
                            android:text="Mahamrtyunjay path"
                            android:textSize="12sp"
                            android:layout_marginTop="7dp"
                            android:textColor="@color/black"
                            />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:visibility="gone"
                            android:id="@+id/tvHanumanPuja"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/hanuman_puja"
                            android:fontFamily="@font/muktamahee_bold"
                            android:textColor="@color/theme"
                            android:layout_marginTop="13dp"
                            android:textSize="12sp"
                            />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:visibility="gone"
                            android:id="@+id/tvLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/_1_25_lakh_mantra"
                            android:fontFamily="@font/muktamahee_regular"
                            android:textColor="@color/black"
                            android:layout_marginTop="7dp"
                            android:textSize="12sp"
                            />
                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvCreateTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/date_time"
                            android:fontFamily="@font/muktamahee_bold"
                            android:textColor="@color/theme"
                            android:layout_marginTop="13dp"
                            android:textSize="12sp"
                            />
                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/tvInr"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="7:00 PM, Aug 28, 2025"
                            android:fontFamily="@font/muktamahee_regular"
                            android:textColor="@color/black"
                            android:layout_marginTop="7dp"
                            android:textSize="12sp"
                            />


            </LinearLayout>
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:paddingVertical="5dp"
                android:paddingHorizontal="10dp"
                android:visibility="gone"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="11dp"
                android:layout_marginBottom="15dp"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:fontFamily="@font/muktamahee_semibold"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:backgroundTint="@color/red"
                android:background="@drawable/rectangle_ff4d00_radius_20"
                app:layout_constraintBottom_toBottomOf="@id/layoutId"
                app:layout_constraintEnd_toEndOf="parent"/>
            <LinearLayout
                android:id="@+id/btnLayoutIdId"
                app:layout_constraintTop_toBottomOf="@+id/layoutId"
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:visibility="gone"
                android:layout_marginHorizontal="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="11dp"
                android:layout_height="wrap_content">
                <com.google.android.material.button.MaterialButton
                    android:layout_width="match_parent"
                    android:layout_weight="1"
                    android:id="@+id/acceptIdBtn"
                    android:text="Accept"
                    android:backgroundTint="@color/green_00da45"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:fontFamily="@font/muktamahee_bold"
                    android:textAllCaps="false"
                    android:layout_marginHorizontal="12dp"
                    android:layout_height="wrap_content"/>
                 <com.google.android.material.button.MaterialButton
                    android:layout_width="match_parent"
                     android:layout_weight="1"
                     android:id="@+id/declineIdBtn"
                     android:text="@string/decline"
                     android:textColor="@color/white"
                     android:textSize="14sp"
                     android:fontFamily="@font/muktamahee_bold"
                     android:textAllCaps="false"
                     android:backgroundTint="@color/red_e30000"
                     android:layout_marginHorizontal="12dp"
                     android:layout_height="wrap_content"/>

            </LinearLayout>
            <androidx.appcompat.widget.AppCompatButton
                android:layout_width="match_parent"
                android:layout_marginHorizontal="15dp"
                android:id="@+id/btnCompleteId"
                android:text="@string/complete"
                android:textAllCaps="false"
                android:background="@drawable/rectangle_000000_radius_12"
                app:layout_constraintBottom_toBottomOf="parent"
                android:textSize="11dp"
                android:layout_marginBottom="10dp"
                android:textColor="@color/white"
                android:fontFamily="@font/muktamahee_bold"
                android:backgroundTint="@color/theme"
                app:layout_constraintTop_toBottomOf="@+id/layoutId"
                android:layout_height="wrap_content"/>


        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</layout>


