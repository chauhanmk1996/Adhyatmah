<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/off_layout"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/rectangle_white">

        <androidx.cardview.widget.CardView
            android:id="@+id/model_image_card"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="14dp"
            android:layout_marginHorizontal="15dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/img_iv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scaleType="fitXY"
                android:src="@drawable/model_image2"/>

        </androidx.cardview.widget.CardView>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/grey_top_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@id/model_image_card"
            app:layout_constraintTop_toTopOf="parent"
            android:text="Grey Top"
            android:textSize="15dp"
            android:textColor="@color/black_272727"
            android:fontFamily="@font/jost"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="16dp" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/order_date_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@id/model_image_card"
            app:layout_constraintTop_toBottomOf="@id/grey_top_tv"
            android:text="13 July, 2024"
            android:textSize="12dp"
            android:layout_marginTop="3dp"
            android:textColor="#7C7C7C"
            android:paddingHorizontal="16dp"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/item_price_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginHorizontal="20dp"
            android:text="₹799"
            android:textColor="@color/black_272727"
            android:layout_marginTop="15dp"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:visibility="gone"
            android:id="@+id/track_layout"
            android:layout_width="72dp"
            android:layout_height="24dp"
            android:background="@drawable/rectangle_track"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/item_price_tv"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="5dp">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/track_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/track"
                android:textColor="@color/white"
                android:textAlignment="center"/>


        </androidx.constraintlayout.widget.ConstraintLayout>






    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
</layout>