<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        tools:context=".presentation.ui.fragment.ConfirmOrderFragment"
        android:background="@color/black_opacity_10"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bagLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="16dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/back_img"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/back_btn"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="40dp"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/confirm_order_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/confirm_order"
                android:textSize="20sp"
                android:textColor="#272727"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/back_img"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="40dp"/>

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/address_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="30dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/back_img"
                android:src="@drawable/address_icon"
                android:layout_marginTop="22dp"/>

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/dots_line1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toStartOf="@+id/payment_disable_btn"
                app:layout_constraintStart_toEndOf="@+id/address_btn"
                app:layout_constraintTop_toBottomOf="@+id/back_img"
                android:src="@drawable/divider_line2"
                android:layout_marginTop="32dp"/>

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/payment_disable_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/back_img"
                android:src="@drawable/payment_enable_icon"
                app:layout_constraintEnd_toStartOf="@+id/dots_line2"
                app:layout_constraintStart_toEndOf="@+id/dots_line1"
                android:layout_marginTop="22dp"/>

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/dots_line2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toEndOf="@+id/payment_disable_btn"
                app:layout_constraintEnd_toStartOf="@+id/order_disable_btn"
                app:layout_constraintTop_toBottomOf="@+id/back_img"
                android:src="@drawable/divider_line2"
                android:layout_marginTop="32dp"/>


            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/order_disable_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="30dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/back_img"
                android:src="@drawable/confirm_order_enable_btn"
                android:layout_marginTop="22dp"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/step3_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/step_3"
                android:textSize="14dp"
                android:layout_marginTop="24dp"
                android:textColor="#7C7C7C"
                android:fontFamily="@font/jost"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/address_btn"/>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/select_payment_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/review_your_order"
                android:textSize="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/step3_tv"
                android:fontFamily="@font/muktamahee_semibold"
                android:textColor="#272727"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/confirm_order_recycler"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scrollbars="vertical"
                android:isScrollContainer="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/select_payment_tv"
                android:layout_marginTop="16dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/empty_text_view"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/no_items_in_your_bag"
                android:textSize="16sp"
                android:textColor="@android:color/darker_gray"
                android:gravity="center"
                android:visibility="gone"
                android:fontFamily="@font/jost_bold"
                app:layout_constraintTop_toBottomOf="@id/select_payment_tv"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp"/>


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/details_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="20sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/confirm_order_recycler"
                android:layout_marginTop="25dp"
                android:background="@drawable/rectangle_white">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/order_address_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/address"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="16dp"
                    android:textSize="15dp"
                    android:fontFamily="@font/muktamahee_semibold"
                    android:textColor="#272727"/>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/user_address_tv"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="Sarang, House no 65..."
                    android:textSize="15dp"
                    android:maxLines="1"
                    android:fontFamily="@font/jost"
                    android:textColor="#272727"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp"/>


                <View
                    android:id="@+id/view_line"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/order_address_tv"
                    android:background="#E3E3E3"
                    android:layout_marginTop="15dp"/>


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/total_amount_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/view_line"
                    android:text="@string/total_amount"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="16dp"
                    android:textSize="15dp"
                    android:fontFamily="@font/muktamahee_semibold"
                    android:textColor="#272727"/>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/rs_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/view_line"
                    android:text="₹1,498"
                    android:textSize="15dp"
                    android:fontFamily="@font/jost"
                    android:textColor="#272727"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp"/>


                <View
                    android:id="@+id/view_line2"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/total_amount_tv"
                    android:background="#E3E3E3"
                    android:layout_marginTop="15dp"/>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/pay_with_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/view_line2"
                    android:text="@string/pay_with"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="16dp"
                    android:textSize="15dp"
                    android:fontFamily="@font/muktamahee_semibold"
                    android:textColor="#272727"/>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/gpay_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/view_line2"
                    android:text="Google Pay"
                    android:textSize="15dp"
                    android:fontFamily="@font/jost"
                    android:textColor="#272727"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp"/>


                <View
                    android:id="@+id/view_line3"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/pay_with_tv"
                    android:background="#E3E3E3"
                    android:layout_marginTop="15dp"/>


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/get_it_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/view_line3"
                    android:text="Get It By"
                    android:visibility="gone"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="16dp"
                    android:textSize="15dp"
                    android:fontFamily="@font/muktamahee_semibold"
                    android:textColor="#272727"/>

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/date_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/view_line3"
                    android:text="13 July, 2024"
                    android:textSize="15dp"
                    android:visibility="gone"
                    android:fontFamily="@font/jost"
                    android:textColor="#272727"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp"
                    android:paddingBottom="16dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>


            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/continue_btn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/rectangle_black"
                android:fontFamily="@font/jost_bold"
                android:gravity="center"
                android:text="@string/place_order"
                android:textColor="@color/white"
                android:textSize="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/details_layout" />
        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>